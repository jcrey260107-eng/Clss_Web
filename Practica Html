<!DOCTYPE html>
<html lang="es">
<head>
   
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
       .cuadrado {
            width: 80px;
            height: 80px;
            background-color: #d3db34ca;
            border-color: rgba(255, 165, 20, 0.734);
            margin: 20px auto;
            position: relative;
        }
       
       .rectangulo {
            width: 80px;
            height: 40px;
            background-color: #34dba1c0;
            border: 2px solid rgba(21, 0, 255, 0.812);
            border-radius: 10px;
            margin: 20px auto;
        }
 
        .circulo {
            width: 40px;
            height: 40px;
            background-color: #39db345a;
            border: 2px solid rgba(127, 0, 139, 0.557);
            border-radius: 50%;
            margin: 20px auto;
        }

    </style>

</head>
<body>
    <div class="cuadrado">
        <p>cuadrado</p>
    </div>
 
    <div class="rectangulo">
        <p>rectangulo<p>
    </div>
   
    <div class="circulo">
    </div>
 
   
</body>
</html>
